# ─────────────────────────────────────────────────
# Variables de entorno — Landing Page (Vercel)
# Copia este archivo como .env.local para desarrollo
# Configura estas variables en Vercel Dashboard para producción
# ─────────────────────────────────────────────────

# ── Stripe Keys ──────────────────────────────────
# Obtén estas keys en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=TU_STRIPE_SECRET_KEY_AQUI

# Webhook secret — Se genera al crear el webhook en Stripe Dashboard
# Dashboard → Developers → Webhooks → Add endpoint
# URL del endpoint: https://tu-dominio.vercel.app/api/webhook/stripe
# Evento a escuchar: checkout.session.completed
STRIPE_WEBHOOK_SECRET=TU_STRIPE_WEBHOOK_SECRET_AQUI

# ── Price IDs de Stripe ──────────────────────────
# Crea los productos en: https://dashboard.stripe.com/products
# Cada plan necesita un Price ID (price_xxx)
STRIPE_PRICE_MENSUAL=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_MENSUAL_EQUIPO=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ANUAL=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ── CRM Backend ───────────────────────────────────
CRM_API_URL=https://api.solomycrm.com

# ── Seguridad interna ─────────────────────────────
# Token secreto compartido entre este serverless y el backend del CRM
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_INTERNAL_SECRET=cambia_esto_por_un_secreto_seguro_aleatorio
